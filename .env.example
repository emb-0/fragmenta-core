# ─────────────────────────────────────────────
# REQUIRED — app will not start without these
# ─────────────────────────────────────────────

# Supabase project URL (Dashboard > Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Dashboard > Settings > API > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — server-side only, never exposed to client
# (Dashboard > Settings > API > service_role secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# OPTIONAL — app runs fine without these;
# features degrade gracefully when unset
# ─────────────────────────────────────────────

# Google Books API key — server-side only
# Used for cover art + metadata enrichment.
# Without it: enrichment silently skips (no crashes, no UI changes).
# Get one at: https://console.cloud.google.com > APIs > Books API
GOOGLE_BOOKS_API_KEY=

# Anthropic API key — server-side only
# Used for AI book summaries (POST /api/books/[id]/summary).
# Without it: summary generation returns a clear error; rest of app unaffected.
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=
